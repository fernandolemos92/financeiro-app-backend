{
  "name": "financeiro-backend",
  "version": "1.0.0",
  "description": "Hono + Postgres backend for financeiro-app",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/scripts/seed-user.ts",
    "seed:2": "tsx src/scripts/create-second-user.ts",
    "seed:ravin": "tsx src/scripts/create-ravin-user.ts",
    "seed:arthur": "tsx src/scripts/create-arthur-user.ts",
    "clean": "tsx src/scripts/clean-data.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@supabase/supabase-js": "^2.45.0",
    "better-auth": "^1.6.2",
    "dotenv": "^17.4.2",
    "hono": "^4.12.0",
    "pg": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "supabase": "^2.89.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5"
  }
